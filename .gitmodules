[submodule "bash/.config/bash/opt/bash-it"]
	path = bash/.config/bash/opt/bash-it
	url = git@github.com:Bash-it/bash-it.git
	ignore = dirty
[submodule "fish/.local/share/omf"]
	path = fish/.local/share/omf
	url = git@github.com:oh-my-fish/oh-my-fish.git
	ignore = dirty
[submodule "fish/.local/share/fisherman"]
	path = fish/.local/share/fisherman
	url = git@github.com:fisherman/fisherman.git
	ignore = dirty
[submodule "zsh/.config/zsh/opt/zgenom"]
	path = zsh/.config/zsh/opt/zgenom
	url = https://github.com/jandamm/zgenom
